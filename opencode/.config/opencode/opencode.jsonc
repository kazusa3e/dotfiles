{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,
    "agent": {},
    "default_agent": "plan",
    "permission": {
        "*": "ask",
        "external_directory": "ask",
        "edit": "ask",
        "bash": {
            "git add *": "ask",
            "git commit *": "ask",
            "git diff *": "allow",
            "git log *": "allow",
            "*": "ask"
        },
        "grep": "allow",
        "glob": "allow",
        "read": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "tavily_tavily_search": "allow",
        "tavily_tavily_research": "allow",
        "tavily_tavily_fetch": "allow",
        "tavily_tavily_extract": "allow",
        "tavily_tavily_map": "allow",
        "tavily_tavily_crawl": "allow"
    },
    "mcp": {
        "tavily": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "tavily-mcp"
            ],
            "environment": {
                "TAVILY_API_KEY": "{env:TAVILY_API_KEY}"
            }
        }
    },
    "share": "disabled",
    "experimental": {
        "openTelemetry": false
    }
}
