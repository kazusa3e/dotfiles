{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "WebSearch",
      "Read",
      "Bash(grep *)",
      "Bash(git log *)",
      "Bash(git diff *)"
    ]
  },
  "effortLevel": "max",
  "theme": "auto",
  "verbose": true,
  "autoCompactEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "hooks": {
    "PreToolUse": [
      {
        "_tag": "ccstatusline-managed",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ],
        "matcher": "Skill"
      }
    ],
    "UserPromptSubmit": [
      {
        "_tag": "ccstatusline-managed",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  }
}
